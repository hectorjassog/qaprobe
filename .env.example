# Required: at least one API key depending on provider
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Provider: "anthropic" (default) or "openai"
# QAPROBE_PROVIDER=anthropic

# Models
# Anthropic models
# QAPROBE_AGENT_MODEL=claude-sonnet-4-6
# QAPROBE_VERIFIER_MODEL=claude-opus-4-7
# QAPROBE_FAST_MODEL=claude-haiku-4-5

# OpenAI models
# QAPROBE_AGENT_MODEL=gpt-5.5
# QAPROBE_VERIFIER_MODEL=gpt-5.5
# QAPROBE_FAST_MODEL=gpt-5.4-mini

# Model routing: use fast model when snapshot has fewer elements than this
# QAPROBE_ROUTING_THRESHOLD=20

# Agent loop
# QAPROBE_MAX_STEPS=40

# Playwright
# QAPROBE_BROWSER_TIMEOUT_MS=30000

# SPA debounce
# QAPROBE_DEBOUNCE_POLL_MS=200
# QAPROBE_DEBOUNCE_STABLE_MS=500
# QAPROBE_DEBOUNCE_TIMEOUT_MS=3000

# Output directory for run artifacts
# QAPROBE_RUNS_DIR=runs
